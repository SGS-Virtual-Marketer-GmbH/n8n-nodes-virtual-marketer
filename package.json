{
  "name": "n8n-nodes-virtual-marketer",
  "version": "0.1.3",
  "description": "n8n community node for the Virtual Marketer AI platform — generate AI-powered marketing text, list AI models and check word usage via the Virtual Marketer API.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "virtual-marketer",
    "ai",
    "text-generation",
    "marketing"
  ],
  "license": "MIT",
  "homepage": "https://virtual-marketer.de",
  "author": {
    "name": "SGS Virtual Marketer GmbH",
    "email": "info@virtual-marketer.de",
    "url": "https://virtual-marketer.de"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SGS-Virtual-Marketer-GmbH/n8n-nodes-virtual-marketer.git"
  },
  "bugs": {
    "url": "https://github.com/SGS-Virtual-Marketer-GmbH/n8n-nodes-virtual-marketer/issues",
    "email": "info@virtual-marketer.de"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/VirtualMarketerApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/VirtualMarketer/VirtualMarketer.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "jest": "^29.7.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
